APP_NAME="Sentimena IDX Sentiment"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Jakarta

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sentimena_dashboard
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

NEWS_PROVIDER=mock
NEWS_API_KEY=
NEWS_API_BASE_URL=https://newsapi.org/v2/everything
NEWS_API_LANGUAGE=id
NEWS_API_TIMEOUT=8
NEWS_API_USER_AGENT=SentimenaNews/1.0
NEWS_RSS_SOURCES=https://www.cnbcindonesia.com/market/rss;https://www.kontan.co.id/rss/finansial;https://www.bisnis.com/rss/finansial
NEWS_RSS_TIMEOUT=8
NEWS_RSS_USER_AGENT=SentimenaBot/1.0
NEWS_RELEVANCE_THRESHOLD=0.25
NEWS_RELEVANCE_HIGH=0.60
GNEWS_API_KEY=
GNEWS_BASE_URL=https://gnews.io/api/v4/search
GNEWS_LANGUAGE=id
GNEWS_COUNTRY=id
GNEWS_TIMEOUT=8
GNEWS_USER_AGENT=SentimenaNews/1.0
STOCK_CHART_MODE=tradingview
TRADINGVIEW_DEFAULT_EXCHANGE=IDX
STOCK_DATA_SOURCE=live
LIVE_MARKET_PROVIDER=http
MARKET_DATA_BASE_URL=https://query2.finance.yahoo.com/v8/finance/chart
MARKET_DATA_API_KEY=
MARKET_DATA_TIMEOUT=8
MARKET_DATA_USER_AGENT=Mozilla/5.0
FALLBACK_TO_SNAPSHOT=true
SENTIMENT_ENGINE=hybrid
PYTHON_SENTIMENT_ENDPOINT=
PYTHON_SENTIMENT_TIMEOUT=5
PYTHON_PREDICTION_ENDPOINT=
PYTHON_RANKING_ENDPOINT=
PREDICTION_ENGINE=baseline

VITE_APP_NAME="${APP_NAME}"
